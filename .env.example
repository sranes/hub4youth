# Database connection string
# Local development uses SQLite (zero setup):
DATABASE_URL=file:./hub4youth.db
# For production, use a Postgres connection string instead and switch the
# adapter in src/payload.config.ts to @payloadcms/db-postgres:
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Active brand theme: teal | emerald | azure | indigo | amber (default: teal)
NEXT_PUBLIC_BRAND_THEME=teal

# ----- Payments (Phase 2) -----
# Active provider: 'razorpay', 'stripe', or 'auto' (INR -> razorpay, else stripe).
# Leave blank to disable checkout (the site still runs; Enroll falls back to enquiry).
PAYMENT_PROVIDER=auto

# Razorpay (test or live keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# The key id must also be exposed to the browser for the Razorpay checkout modal:
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Stripe (test or live keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Email (Phase 3, Resend) -----
# Leave RESEND_API_KEY blank to log emails to the console instead of sending.
RESEND_API_KEY=
EMAIL_FROM=hello@hub4youth.ai
EMAIL_FROM_NAME=hub4youth
# Where new-enquiry / new-enrollment notifications are sent (optional):
ENQUIRY_NOTIFY_EMAIL=

# ----- Student auth -----
# How long a password-reset link stays valid (minutes). Default 60.
PASSWORD_RESET_EXPIRATION_MINUTES=60
# How long an emailed 2FA login code stays valid (minutes). Default 10.
TWO_FACTOR_CODE_EXPIRATION_MINUTES=10

# ----- Production / Vercel -----
# In production set DATABASE_URL to a Postgres connection string (e.g. Neon via
# the Vercel Marketplace) — the adapter auto-switches to Postgres when it starts
# with "postgres". Locally, leave it as the SQLite file URL above.
# Vercel Blob token — required in production so media uploads persist
# (the serverless filesystem is ephemeral). Provisioned by adding Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Postgres TLS: by default the connection is encrypted but the cert chain is not
# verified (avoids "self-signed certificate in certificate chain" with managed
# providers). Set to "true" only if you supply the provider's CA to Node.
DATABASE_SSL_STRICT=
# Set to "true" to disable TLS entirely — only for a local/dev Postgres with no
# SSL (e.g. a Docker container used to generate migrations). Never use in prod.
DATABASE_DISABLE_SSL=
